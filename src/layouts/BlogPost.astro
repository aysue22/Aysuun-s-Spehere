---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { CollectionEntry } from 'astro:content';
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
const { title, description, pubDate, updatedDate, heroImage, theme } = Astro.props;

type Props = CollectionEntry<'blog'>['data'];


---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
  
  html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  overflow-x: hidden;
}


  /* TÜM SİTENİN ARKA PLANI */
  body {
    background-color: #2d3e2d !important; /* O sevdiğin yeşil */
    margin: 0;
    padding: 0;
    font-family: 'Crimson Text', serif !important;
    background-image: radial-gradient(#000 0.5px, transparent 0.5px) !important;
    background-size: 5px 5px !important;
    background-attachment: fixed !important;
  }

  /* TÜM SAYFALARIN ANA KUTUSU (Parşömen) */
   main {
  max-width: 900px;
  margin: 50px auto;


    background: #fdfaf1 !important; 
    padding: 50px;
    border-radius: 5px;
    box-shadow: 0 0 50px rgba(0,0,0,0.5);
    border: 1px solid #d4af37;
    color: #2c2c2c;
  }

  /* HEADER SEKMELERİ (Etiket Modu) */
  header a {
    font-family: 'Crimson Text', serif !important; 
    font-weight: 700 !important;
    font-size: 1.1rem !important;
    text-transform: uppercase;
    color: #1a1a1a !important;      
    background: #e9dcc9 !important;  
    padding: 8px 18px !important;
    margin: 0 5px !important;
    text-decoration: none !important;
    display: inline-block !important;
    border: 1px solid #3e2723; 
    box-shadow: 4px 4px 0px #d4af37; 
    transform: rotate(-1.5deg);
    transition: all 0.2s ease;
  }

  header a:hover {
    background: #1a1a1a !important;
    color: #fdfaf1 !important;    
    transform: rotate(0deg) translateY(-3px);
  }
  /* YEŞİL TEMA ÖZELLEŞTİRMESİ */
  main.green-theme {
    background: #e1f2e1 !important; /* Parşömen yerine taze yeşil */
    border: 2px solid #2e7d32 !important;
    box-shadow: 0 0 30px rgba(46, 125, 50, 0.4) !important;
  }

  /* RESMİN RENKLENMESİNİ SAĞLAYAN KRİTİK KOD */
  main.green-theme img {
    filter: none !important; /* Siyah-beyaz filtreyi zorla kaldırır */
    -webkit-filter: grayscale(0) !important; /* Safari için */
    border: 3px solid #4caf50 !important;
    border-radius: 8px;
  }

  main.green-theme h1 {
    color: #1b5e20 !important;
  }
  img, .hero-image img, article img {
    filter: none !important;
    -webkit-filter: grayscale(0) !important;
    filter: grayscale(0) !important;
  }

  /* EĞER RESİM HALA RENKLENMİYORSA, MUHTEMELEN BİRİ ÜSTÜNE ŞEFFAF SİYAH BİR KATMAN KOYMUŞTUR */
  .hero-image::after {
    display: none !important;
  }
  body:has(.dark-blog-theme) {
    background-color: #000000 !important;
    background-image: radial-gradient(#333 0.5px, transparent 0.5px) !important;
    
  }

  main.dark-blog-theme {
  background: #ffffff !important;
  color: #000000 !important;
}

  
  /* SADECE DÖRDÜNCÜ YAZI (DARK-MODE) İÇİN HER ŞEYİ SIFIRLA */
  html:has(.dark-blog-theme), 
  body:has(.dark-blog-theme) {
    background: #ffffff !important; /* İncele'de gördüğün o griyi ve gradyanı siler */
    background-color: #ffffff !important;
    background-image: none !important; 
  }

  main.dark-blog-theme {
    background: #ffffff !important; /* Yazı kutusu tam beyaz */
    color: #000000 !important;      /* Yazılar tam siyah */
    border: none !important;
    box-shadow: 0 0 60px rgba(255, 255, 255, 0.2) !important;
  }

  /* Yazı alanındaki tüm metinleri siyah yap */
  main.dark-blog-theme .prose, 
  main.dark-blog-theme h1, 
  main.dark-blog-theme p, 
  main.dark-blog-theme li {
    color: #ffffff !important;
  }
</style>

	</head>

	<body>
		<Header />
		<main class={theme === 'green'
  ? 'green-theme'
  : theme === 'dark-mode'
  ? 'dark-blog-theme'
  : ''
}>

			<article>
				<div class="hero-image">
					{heroImage && <img src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
    {pubDate && (
  <FormattedDate date={new Date(pubDate)} />
)}

    
    {updatedDate && (
        <div class="last-updated-on">
            Son güncelleme: <FormattedDate date={new Date(updatedDate)} />
        </div>
    )}
</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
