---
import BlogPost from '../layouts/BlogPost.astro';
---

<BlogPost title="Who is this?" description="" noPaper={true}>

	<div class="who-container">
		<h1 class="manual-title">Who is this?</h1>

		<section class="who-content">
			<p class="main-text">
				I am a sociology student based in Turkey, working at the intersection of ecology, feminism, cinema, and public life.
			</p>

			<p class="sub-text">
				This magazine is an independent space for essays, reports, and collective writing outside institutional constraints. This project is self-funded and maintained without advertisements or corporate backing.
			</p>

			<p class="sub-text">
				It exists through time, care, and unpaid labor. If you find this work meaningful, you can support it through Ko-fi.
			</p>

			<div class="kofi-wrapper">
				<a href="https://ko-fi.com/KULLANICI_ADIN" target="_blank" class="kofi-button">
					☕ Support on Ko-fi
				</a>
			</div>

			<p class="disclaimer-text">
				Your contribution helps cover basic expenses such as hosting, archiving, and production.
				<strong>Support does not influence editorial decisions.</strong>
				This space remains independent and non-commercial.
			</p>
		</section>
	</div>

</BlogPost>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
	}

	/* ── ARKA PLAN ── */
	html {
		background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)),
		            url("/arkaplan10.jpg") no-repeat center center fixed !important;
		background-size: cover !important;
		background-color: #1a1a1a !important;
	}

	/* Tüm katmanları şeffaf yap */
	html body,
	main,
	article,
	section,
	.who-container {
		background-color: transparent !important;
		background-image: none !important;
		box-shadow: none !important;
		border: none !important;
	}

	/* ── KAPSAYICI ── */
	.who-container {
		width: 90%;
		max-width: 750px;
		margin: clamp(60px, 12vw, 100px) auto clamp(40px, 8vw, 80px);
		padding-top: clamp(30px, 6vw, 50px);
	}

	/* ── BAŞLIK ── */
	.manual-title {
		font-family: 'Crimson Text', serif !important;
		font-size: clamp(1.1rem, 4vw, 2rem) !important;
		text-transform: uppercase;
		background-color: #69622b !important;
		color: #f0e6d2 !important;
		display: table !important;
		margin: 0 auto 0 auto !important;
		padding: 10px 25px !important;
		border: 1px solid #3e2723;
		box-shadow: 5px 5px 0px #000;
		position: relative;
		z-index: 10;
		transform: translateY(50%);
		text-align: center;
	}

	/* Diğer h1'leri gizle (layout'tan gelen boş başlık) */
	h1:not(.manual-title) {
		display: none !important;
	}

	/* ── İÇERİK KUTUSU ── */
	.who-content {
		background-color: rgba(240, 230, 210, 0.95) !important;
		padding: clamp(50px, 8vw, 70px) clamp(20px, 6vw, 50px) clamp(30px, 6vw, 50px);
		border: 1px solid #3e2723;
		box-shadow: 15px 15px 0px rgba(188, 149, 212, 0.4);
		color: #3e2723 !important;
		font-family: 'Georgia', serif;
		line-height: 1.8;
		width: 100%;
	}

	/* ── METİNLER ── */
	.main-text {
		font-size: clamp(1rem, 3vw, 1.4rem);
		font-weight: bold;
		margin: 0 0 1.5rem 0;
	}

	.sub-text {
		font-size: clamp(0.9rem, 2.5vw, 1.1rem);
		margin: 0 0 1.2rem 0;
	}

	.disclaimer-text {
		font-size: clamp(0.8rem, 2vw, 0.9rem);
		opacity: 0.85;
		margin: 1.5rem 0 0 0;
		border-top: 1px dashed #3e2723;
		padding-top: 1rem;
	}

	/* ── KO-FI BUTONU ── */
	.kofi-wrapper {
		margin: 1.5rem 0;
	}

	.kofi-button {
		background-color: #f0e6d2 !important;
		color: #1a1a1a !important;
		padding: 10px 20px !important;
		text-decoration: none !important;
		font-weight: 700;
		border: 1px solid #3e2723;
		box-shadow: 4px 4px 0px #bc95d4;
		display: inline-block;
		transition: all 0.2s ease;
	}

	.kofi-button:hover {
		background-color: #bc95d4 !important;
		transform: translateY(-2px);
		box-shadow: 6px 6px 0px #000;
	}

	/* ── MOBİL (≤480px) ── */
	@media (max-width: 480px) {
		.who-container {
			width: 95%;
		}

		.manual-title {
			/* Mobilde translateY taşması sorunu yaratabilir, azalt */
			transform: translateY(40%);
		}

		.who-content {
			box-shadow: 8px 8px 0px rgba(188, 149, 212, 0.4);
		}

		.kofi-button {
			display: block;
			text-align: center;
		}
	}

	/* ── HAREKET HASSAS ── */
	@media (prefers-reduced-motion: reduce) {
		.kofi-button:hover {
			transform: none;
		}
	}
	@media (max-width: 600px) {
  .who-content {
    padding: 30px 20px !important;
  }
}
</style>

<script is:inline>
	function setBackground() {
		const html = document.documentElement;
		const body = document.body;

		html.style.setProperty('background', 'none', 'important');
		body.style.setProperty('background', 'none', 'important');

		html.style.backgroundImage = "linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/arkaplan10.jpg')";
		html.style.backgroundSize = "cover";
		html.style.backgroundPosition = "center";
		html.style.backgroundAttachment = "fixed";
		html.style.backgroundColor = "#1a1a1a";
	}

	setBackground();
	document.addEventListener('astro:after-swap', setBackground);
</script>