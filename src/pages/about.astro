---
import BlogPost from '../layouts/BlogPost.astro';
---

<BlogPost title=""> <main class="who-container"> 

    <h1 class="manual-title">Who is this?</h1>
		<section class="who-content">
			

			<p class="main-text">
				I am a sociology student based in Turkey, working at the intersection of ecology, feminism, cinema, and public life.
			</p>

			<p class="sub-text">
				This magazine is an independent space for essays, reports, and collective writing outside institutional constraints. This project is self-funded and maintained without advertisements or corporate backing.
			</p>

			<p class="sub-text">
				It exists through time, care, and unpaid labor. If you find this work meaningful, you can support it through Ko-fi.
			</p>

			<div class="kofi-wrapper">
				<a href="https://ko-fi.com/KULLANICI_ADIN" target="_blank" class="kofi-button">
					☕ Support on Ko-fi
				</a>
			</div>

			<p class="disclaimer-text">
				Your contribution helps cover basic expenses such as hosting, archiving, and production. 
				<strong>Support does not influence editorial decisions.</strong> 
				This space remains independent and non-commercial.
			</p>
		</section>
	</main>
</BlogPost>



<style is:global>

  /* 1. Tüm katmanları şeffaf yapıyoruz ki en arkadaki HTML görünsün */
  html, body, main, article, section, .who-container {
    background-color: transparent !important;
    background-image: none !important;
  }

  /* 2. Arka planı doğrudan en temele, HTML'e gömüyoruz */
  html {
    background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
                url("/arkaplan10.jpg") no-repeat center center fixed !important;
    background-size: cover !important;
    background-color: #1a1a1a !important; /* Resim yüklenene kadar siyah kalsın */
  }

  /* 3. Senin fanzine tasarımı (Burası aynı kalabilir) */
  .who-content {
    background-color: rgba(240, 230, 210, 0.95) !important;
    padding: 60px 40px;
    border: 1px solid #3e2723;
    box-shadow: 15px 15px 0px rgba(188, 149, 212, 0.4);
    color: #3e2723 !important;
    position: relative;
    z-index: 1;
  }

  .manual-title {
    background-color: #69622b !important;
    color: #f0e6d2 !important;
    display: table !important; 
    margin: -40px auto 40px auto !important;
    padding: 10px 25px !important;
    box-shadow: 5px 5px 0px #000;
    position: relative;
    z-index: 10;
  }

  /* 4. SENİN TASARIMIN (Krem kolonun ve başlığın burada kalsın) */
  .who-content {
    background-color: rgba(240, 230, 210, 0.95) !important;
    /* ... diğer ayarların ... */
  }

  .who-content {
    background-color: rgba(240, 230, 210, 0.95) !important; /* Kirli kağıt rengi */
    padding: 60px 40px;
    border: 1px solid #3e2723;
    box-shadow: 15px 15px 0px rgba(188, 149, 212, 0.4); /* Mor gölge */
    color: #3e2723 !important;
    font-family: 'Georgia', serif;
    line-height: 1.8;
  }

  /* 3. BAŞLIK: Who is this? */
  .manual-title {
    background-color: #69622b !important; /* Zeytin/Krem */
    color: #f0e6d2 !important;
    display: table !important; 
    margin: -40px auto 40px auto !important;
    padding: 10px 25px !important;
    font-family: 'Crimson Text', serif !important;
    text-transform: uppercase;
    font-size: 2rem !important;
    border: 1px solid #3e2723;
    position: relative;
    z-index: 10;
    box-shadow: 5px 5px 0px #000;
  }

  /* Eski başlığı gizle */
  h1:not(.manual-title) {
    display: none !important;
  }

  /* 4. BUTON VE DİĞERLERİ */
  .kofi-button {
    background-color: #f0e6d2 !important;
    color: #1a1a1a !important;
    padding: 10px 20px !important;
    text-decoration: none !important;
    font-weight: 700;
    border: 1px solid #3e2723;
    box-shadow: 4px 4px 0px #bc95d4;
    display: inline-block;
  }

  .main-text {
    font-size: 1.4rem;
    font-weight: bold;
    margin-bottom: 2rem;
  }

  /* Layout şeffaflığı */
  main, .container {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
  }
</style>
<script is:inline>
  // Bu script Vercel'de sayfa yüklendiği an çalışır ve 
  // temayı (layout) bypass ederek resmi direkt arka plana çiviler.
  
  function setBackground() {
    const htmlEl = document.documentElement;
    const bodyEl = document.body;

    // Önce temadan gelen tüm engelleri kaldırıyoruz
    htmlEl.style.setProperty('background', 'none', 'important');
    bodyEl.style.setProperty('background', 'none', 'important');
    
    // Şimdi resmi en tepeye yerleştiriyoruz
    htmlEl.style.backgroundImage = "linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/arkaplan10.jpg')";
    htmlEl.style.backgroundSize = "cover";
    htmlEl.style.backgroundPosition = "center";
    htmlEl.style.backgroundAttachment = "fixed";
    htmlEl.style.backgroundColor = "#1a1a1a";
  }

  // Sayfa ilk açıldığında çalıştır
  setBackground();
  
  // Astro'nun sayfa geçişlerinde (eğer varsa) tekrar çalışması için
  document.addEventListener('astro:after-swap', setBackground);
</script>