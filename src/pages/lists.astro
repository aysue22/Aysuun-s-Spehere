---
import Layout from '../layouts/BlogPost.astro';

const books = [
  { title: "Yolpalas Cinayeti", author: "Halide Edip" },
  { title: "Matmazel Noraliya’nın Koltuğu", author: "Peyami Safa" },
  { title: "Gece Savaşları", author: "Carlo Ginzburg" }
];

const movies = [
  { title: "Suspiria", director: "Luca Guadagnino" },
  { title: "Blade", director: "Stephen Norrington" },
  { title: "Kız Kardeşler", director: "Emin Alper" }
];
---

<Layout title="🧙🏻‍♀️🧹🪄🐈‍⬛" noPaper={true}>
  <main class="alchemy-room">
  <h1 class="shelf-title">The Alchemist's Shelf</h1>

  <div class="alchemy-container">
    <div class="bookshelf-bg">
      
      <div class="shelf-label"><span>GRIMOIRES & BOOKS</span></div>
      
      <section class="shelf-layer">
        <div class="potion-grid">
          {books.map((book) => (
            <div class="potion-bottle">
              <img src="/potions/potion1.png" class="potion-img-element" alt="Potion" />
              <div class="potion-inner-text">
                <span class="magic-title">{book.title}</span>
                <span class="magic-info">{book.author}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <div class="shelf-label"><span>VISIONS & CINEMA</span></div>

      <section class="shelf-layer">
        <div class="potion-grid">
          {movies.map((movie) => (
            <div class="potion-bottle">
              <img src="/potions/potion1.png" class="potion-img-element" alt="Potion" />
              <div class="potion-inner-text">
                <span class="magic-title">{movie.title}</span>
                <span class="magic-info">{movie.director}</span>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</main>
</Layout>

<style is:global>

/* Sadece başlıkların etrafındaki o zoraki beyaz alanları yok eder */
  .shelf-title, 
  .shelf-label, 
  .shelf-label span {
    background-color: transparent !important; /* Arka planı şeffaf yapar */
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    box-shadow: none !important; /* Beyaz gölge sızıntısını engeller */
  }

  /* Başlığın Layout içindeki yerleşim boşluğunu temizler */
  .alchemy-room {
    display: flow-root !important; /* Beyazlığın sızmasını engelleyen bariyer */
    padding-top: 1px !important;
  }

  .shelf-label {
    display: flex;
    justify-content: center;
    margin: 50px 0 20px 0; /* Üstten ve alttan boşluk */
    width: 100%;
    position: relative;
    z-index: 10;
  }

  /* Yazının arkasındaki etiket (Burası beyazlığı kapatacak olan yer) */
  .shelf-label span {
    background-color: #000000 !important; /* Arka planı simsiyah yapar, beyazlık kalmaz */
    color: #d4af37 !important;           /* Altın rengi yazı */
    padding: 10px 30px !important;
    border: 2px solid #d4af37;           /* Çerçeve */
    display: inline-block;
    box-shadow: 0 0 20px rgba(0,0,0,1);  /* Gölge ile derinlik */
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

.alchemy-room {
display: block !important; /* Flex'i iptal et */
    margin-top: 0 !important;
    padding-top: 1px !important; /* Margin sızıntısını önleyen görünmez bariyer */
    background: transparent !important;
}

.shelf-title {
 margin: 0 auto 40px auto !important;
    display: table; /* Başlığın genişliğini yazısı kadar yapar */
    padding: 15px 40px !important;
}

/* EFEKT MOTORLARI - En üste yapıştır */
@keyframes spellGlow {
  0% { text-shadow: 0 0 5px rgba(232, 224, 224, 0.4); opacity: 0.8; }
  50% { text-shadow: 0 0 15px rgba(255, 255, 255, 0.9); opacity: 1; }
  100% { text-shadow: 0 0 5px rgba(232, 224, 224, 0.4); opacity: 0.8; }
}

@keyframes floatInPotion {
  0% { transform: translate(-50%, -48%); }
  50% { transform: translate(-50%, -52%); }
  100% { transform: translate(-50%, -48%); }
}

  /* 1. TEMEL SIFIRLAMA */
  html, body, main {
    background: transparent !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
  }

html, body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    background: transparent !important;
  }

  html::before {
    content: "";
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: -1;
    /* Senin orijinal arkaplanın */
    background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
                      url('/arkaplan3.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    /* GLOBAL RESET */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* LISTS PAGE FIX */
ul, li {
  list-style: none;
  margin: 0;
  padding: 0;
}

main {
  max-width: 900px;
  margin: 0 auto 50px auto !important;
}

  }
  /* ANA TAŞIYICI */
  .alchemy-container {
    width: 100%;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    padding: 50px 0;
  }

  /* KİTAPLIK PNG'Sİ */
  .bookshelf-bg {
    background-image: url('/potions/kitaplıkraf.jpg'); /* Buraya kendi PNG ismini yaz */
    min-height: 1200px;
    background-size: 130% auto;
    background-repeat: repeat-y;
    width: 1000px; /* Görselin genişliğine göre ayarla */
    padding: 100px 0; /* Rafların en üstten başlaması için */
    display: flex;
    flex-direction: column;
    gap: 230px; /* PNG'ndeki iki raf arasındaki mesafe ne kadarsa burayı ona göre ayarla */
  }

  /* RAF KATMANI */
  .shelf-layer {
    width: 100%;
    display: flex;
    justify-content: center;
    /* Şişelerin rafın tam çizgisine basması için alt padding */
    padding-bottom: 10px; 
  }

  .potion-grid {
    display: flex;
    gap: 60px;
    align-items: flex-end; /* Şişe tabanlarını rafa hizalar */
  }

  .potion-img-element {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 15px 10px rgba(0,0,0,0.8));
    mix-blend-mode: multiply; /* Şeffaflık için */
  }


  @keyframes floatInPotion {
    0% { transform: translate(-50%, -48%); }
    50% { transform: translate(-50%, -52%); }
    100% { transform: translate(-50%, -48%); }
  }

  
  /* 3. BAŞLIK */
  .shelf-title {
    background: #e4dbb4 !important;
    color: #0f0e0a !important;
    padding: 15px 30px !important;
    font-family: 'UnifrakturMaguntia', cursive !important;
    font-size: 3rem !important;
    transform: rotate(-1.5deg);
    border: 3px double #d4af37 !important;
    box-shadow: 8px 8px 0px #3e2723 !important;
    text-align: center;
  }

  .potion-grid {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 50px;
    flex-wrap: wrap;
  }

 .potion-bottle { 
  width: 300px; 
  position: relative; /* İçindeki her şey buna göre hizalanacak */
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 5; /* Ana katman */
}

/* PNG RESMİ (Arkadaki Şişe) */
.potion-img-element {
  width: 100%;
  height: auto;
  position: relative; 
  z-index: 1; /* Resim en altta kalsın */
  mix-blend-mode: multiply; /* Arka plan beyazsa bunu ekle */
  filter: drop-shadow(0 10px 10px rgba(0,0,0,0.5));
}



 .potion-inner-text {
    position: absolute;
    z-index: 10;
    width: 80%; /* Yazılar şişenin kenarlarından taşmasın */
    text-align: center;
    pointer-events: none; /* Mouse etkileşimini bozmasın */
    display: flex;
    flex-direction: column;
    gap: 4px;
    /* Yazıları biraz yukarı veya aşağı almak istersen burayı kurcala */
    top: 55%; 
    left: 50%;
    animation: floatInPotion 4s infinite ease-in-out; 
  
  z-index: 10;
  width: 70%; 
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 4px;
    
  }

  .magic-title {
    display: -webkit-box;
  -webkit-line-clamp: 2;   /* kitap adı max 2 satır */
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 0.85rem;
  line-height: 1.1;
    font-family: 'Crimson Text', serif;
    font-weight: bold;
    font-size: 0.9 rem;
    color: #6a1133; /* Eğer iksirin koyuysa burayı #8a195c (açık sarı) yap */
    line-height: 1.1;
    text-shadow: 0px 0px 5px rgba(255, 255, 255, 0.5); /* Yazı okunabilsin diye hafif parıltı */
    animation: spellGlow 3s infinite ease-in-out;
    
  }

  .magic-info {
    display: -webkit-box;
  -webkit-line-clamp: 1;   /* yazar adı tek satır */
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 0.6rem;
    font-family: 'Crimson Text', serif;
    font-style: italic;
    font-size: 0.6rem;
    color: #d6ccca;
    opacity: 0.8;
    
  }
  

  /* HOVER: Üzerine gelince yazılar parlasın */
  .potion-bottle:hover .magic-title {
    color: #6f721b; /* Kan kırmızısı veya iksirin rengine göre bir renk */
    text-shadow: 0px 0px 10px rgba(202, 205, 52, 0.8);
    text-shadow: 0px 0px 15px rgba(205, 52, 187, 1), 0px 0px 30px rgba(205, 52, 187, 0.5);
  transition: all 0.4s ease;
  }
  

  /* 7. HOVER ETKİSİ */
  .potion-bottle:hover {
    transform: scale(1.15) translateY(-20px);
  }

  .potion-bottle:hover .potion-img-element {
    filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.7));
  }
  
  /* ŞİŞE: MASKE */
.potion-bottle {
  width: 300px;
  position: relative;
  overflow: hidden; /* taşanı KES */
}

/* PNG */
.potion-img-element {
  width: 100%;
  height: auto;
  z-index: 1;
}

/* YAZI ALANI (sabit alan) */
.potion-inner-text {
  position: absolute;
  top: 55%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 70%;
  max-height: 60px;      /* <<< KRİTİK */
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 4px;
  text-align: center;
  z-index: 10;
}

</style>