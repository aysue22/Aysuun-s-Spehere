---
import Layout from '../layouts/BlogPost.astro';

const books = [
  {
    title: "Yolpalas Cinayeti",
    author: "Halide Edip",
    note: "Dedektif kurguyla örülmüş, dönemin İstanbul'unu nefes nefese yaşatan bir roman.",
    stars: 4,
    potion: "/potions/ppotion2.png",
  },
  {
    title: "Matmazel Noraliya'nın Koltuğu",
    author: "Peyami Safa",
    note: "Ruh ve madde arasında sıkışmış bir kadının hikâyesi. Ağır ama bırakamıyorsunuz.",
    stars: 5,
    potion: "/potions/ppotion3.png",
  },
  {
    title: "Gece Savaşları",
    author: "Carlo Ginzburg",
    note: "Mikrotarih ustasının büyülü gerçekçilikle harmanlanmış cadılık araştırması.",
    stars: 4,
    potion: "/potions/ppotion4.png",
  },
];

const movies = [
  {
    title: "Suspiria",
    author: "Luca Guadagnino",
    note: "Orijinalin gölgesinde değil, yanında duran cesur bir yorum. Dans sahnesi unutulmaz.",
    stars: 4,
    potion: "/potions/ppotion5.png",
  },
  {
    title: "Blade",
    author: "Stephen Norrington",
    note: "90'ların en sert aksiyon-korku karışımı. Snipes her karede sahneye hâkim.",
    stars: 4,
    potion: "/potions/ppotion6.png",
  },
  {
    title: "Kız Kardeşler",
    author: "Emin Alper",
    note: "Türk sinemasının nadir sessiz gerilim başarılarından. Atmosfer baştan sona boğucu.",
    stars: 5,
    potion: "/potions/ppotion8.png",
  },
];

function stars(n: number) {
  return "★".repeat(n) + "☆".repeat(5 - n);
}
---

<Layout title="🧙🏻‍♀️🧹🪄🐈‍⬛" noPaper={true}>
  <main class="alchemy-room">

    <h1 class="shelf-title">The Alchemist's Shelf</h1>

    <div class="alchemy-container">
      <div class="bookshelf-bg">

        <!-- RAF 1: KİTAPLAR -->
        <div class="shelf-group">
          <div class="shelf-label"><span>GRIMOIRES &amp; BOOKS</span></div>
          <section class="shelf-layer">
            <div class="potion-grid">
              {books.map((item) => (
                <div class="potion-bottle">
                  <div class="bubbles-container">
                    <span class="bubble"></span>
                    <span class="bubble"></span>
                    <span class="bubble"></span>
                  </div>
                  <img src={item.potion} class="potion-img-element" alt={item.title} />
                  <div class="tooltip-card" role="tooltip">
                    <p class="tc-title">{item.title}</p>
                    <p class="tc-by">{item.author}</p>
                    <p class="tc-note">{item.note}</p>
                    <p class="tc-stars">{stars(item.stars)}</p>
                  </div>
                  <span class="bottle-name">{item.title}</span>
                </div>
              ))}
            </div>
          </section>
        </div>

        <!-- RAF 2: FİLMLER -->
        <div class="shelf-group">
          <div class="shelf-label"><span>VISIONS &amp; CINEMA</span></div>
          <section class="shelf-layer">
            <div class="potion-grid">
              {movies.map((item) => (
                <div class="potion-bottle">
                  <div class="bubbles-container">
                    <span class="bubble"></span>
                    <span class="bubble"></span>
                    <span class="bubble"></span>
                  </div>
                  <img src={item.potion} class="potion-img-element" alt={item.title} />
                  <div class="tooltip-card" role="tooltip">
                    <p class="tc-title">{item.title}</p>
                    <p class="tc-by">{item.author}</p>
                    <p class="tc-note">{item.note}</p>
                    <p class="tc-stars">{stars(item.stars)}</p>
                  </div>
                  <span class="bottle-name">{item.title}</span>
                </div>
              ))}
            </div>
          </section>
        </div>

      </div>
    </div>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }
  ul, li { list-style: none; }

  /* ── Arka plan override (Layout'un !important'ını geçer) ── */
  body:has(.alchemy-room) {
    background-color: transparent !important;
    background-image: none !important;
  }

  body:has(.alchemy-room)::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(rgba(0,0,0,0.70), rgba(0,0,0,0.70)),
      url('/arkaplan3.jpg') center / cover no-repeat;
  }

  /* ── Ana alan ── */
  .alchemy-room {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
    max-width: 100% !important;
    margin: 0 auto !important;
    padding: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
  }

  /* ── Animasyonlar ── */
  @keyframes spellGlow {
    0%   { text-shadow: 0 0 5px rgba(232,224,224,0.4); opacity: 0.8; }
    50%  { text-shadow: 0 0 15px rgba(255,255,255,0.9); opacity: 1; }
    100% { text-shadow: 0 0 5px rgba(232,224,224,0.4); opacity: 0.8; }
  }

  @keyframes riseUp {
    0%   { opacity: 0;   transform: translateX(-50%) scale(0)   translateY(0px); }
    15%  { opacity: 0.9; transform: translateX(-50%) scale(1)   translateY(-8px); }
    85%  { opacity: 0.4; transform: translateX(-50%) scale(1.1) translateY(-60px); }
    100% { opacity: 0;   transform: translateX(-50%) scale(0.6) translateY(-75px); }
  }

  /* ── Başlık ── */
  .shelf-title {
    display: table;
    margin: 30px auto 40px auto !important;
    padding: 15px 40px !important;
    background: #e4dbb4 !important;
    color: #0f0e0a !important;
    font-family: 'UnifrakturMaguntia', cursive !important;
    font-size: 3rem !important;
    transform: rotate(-1.5deg);
    border: 3px double #d4af37 !important;
    box-shadow: 8px 8px 0px #3e2723 !important;
    text-align: center;
  }

  /* ── Raf etiketi ── */
  .shelf-label {
    display: flex;
    justify-content: center;
    width: 100%;
    position: relative;
    z-index: 20;
    margin-bottom: -20px;
  }

  .shelf-label span {
    background-color: #000 !important;
    color: #d4af37 !important;
    padding: 4px 15px !important;
    border: 1px solid #d4af37;
    display: inline-block;
    box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-family: 'Crimson Text', serif;
  }

  /* ── Container ── */
  .alchemy-room { display: block !important; width: 100%; }

  .alchemy-container {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 20px 0 50px;
  }

  /* ── Kitaplık görseli ── */
  .bookshelf-bg {
    background-image: url('/potions/pngwing.com.png');
    background-size: 100% 100%;
    background-repeat: no-repeat;
    width: 800px;
    height: 850px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    padding: 180px 80px 100px 80px;
    gap: 40px;
    margin: 0 auto;
  }

  /* ── Raf grupları ── */
  .shelf-group {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 350px;
  }

  .shelf-layer {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: visible;
  }

  .potion-grid {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 20px;
    width: 100%;
    overflow: visible;
    padding-bottom: 70px;
  }

  /* ── İksir şişesi ── */
  .potion-bottle {
    width: 160px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 5;
    overflow: visible;
    cursor: pointer;
    transition: transform 0.3s ease, z-index 0s;
  }

  .potion-bottle:hover {
    transform: scale(1.15) translateY(-14px);
    z-index: 100;
  }

  /* ── PNG görseli ── */
  .potion-img-element {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.6));
    transition: filter 0.3s ease;
  }

  .potion-bottle:hover .potion-img-element {
    filter: drop-shadow(0 0 16px rgba(212,175,55,0.8));
  }

  /* ── Şişe altı isim ── */
  .bottle-name {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: 'Crimson Text', serif;
    font-size: 0.72rem;
    font-weight: 600;
    color: #e0cfa0;
    text-align: center;
    line-height: 1.2;
    max-width: 90px;
    margin-top: 5px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.9);
    animation: spellGlow 3s infinite ease-in-out;
  }

  /* ── Tooltip kart ── */
  .tooltip-card {
    display: none;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    width: 190px;
    padding: 12px 14px;
    background: #1a1008;
    border: 1px solid rgba(212,175,55,0.4);
    border-radius: 8px;
    box-shadow: 0 10px 32px rgba(0,0,0,0.85), 0 0 0 1px rgba(212,175,55,0.12);
    pointer-events: none;
    z-index: 200;
    font-family: 'Crimson Text', serif;
  }

  .tooltip-card::after {
    content: "";
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 7px solid transparent;
    border-top-color: rgba(212,175,55,0.4);
  }

  .potion-bottle:hover .tooltip-card {
    display: block;
    animation: cardAppear 0.18s ease;
  }

  @keyframes cardAppear {
    from { opacity: 0; transform: translateX(-50%) translateY(6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .tc-title {
    font-weight: 600;
    font-size: 0.88rem;
    color: #e8d8b0;
    line-height: 1.3;
    margin-bottom: 3px;
  }

  .tc-by {
    font-size: 0.68rem;
    font-style: italic;
    color: #9a7850;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(212,175,55,0.2);
    margin-bottom: 8px;
  }

  .tc-note {
    font-size: 0.72rem;
    font-style: italic;
    color: #c4b090;
    line-height: 1.55;
  }

  .tc-stars {
    margin-top: 8px;
    font-size: 0.74rem;
    color: #d4af37;
    letter-spacing: 1px;
  }

  /* ── Baloncuklar ── */
  .bubbles-container {
    position: absolute;
    top: 6%;
    left: 50%;
    width: 50px;
    height: 20px;
    z-index: 30;
    pointer-events: none;
    overflow: visible;
  }

  .bubble {
    position: absolute;
    bottom: 0;
    border-radius: 50%;
    opacity: 0;
    transform: translateX(-50%) scale(0);
    background: radial-gradient(circle at 35% 35%, rgba(255,210,230,0.95), rgba(255,140,190,0.7));
    border: 1px solid rgba(255,180,220,0.8);
  }

  .bubble:nth-child(1) { left: 8px;  width: 7px;  height: 7px; }
  .bubble:nth-child(2) { left: 22px; width: 10px; height: 10px; }
  .bubble:nth-child(3) { left: 36px; width: 6px;  height: 6px; }

  .potion-bottle:hover .bubble:nth-child(1) { animation: riseUp 1.6s ease-in 0s      infinite; }
  .potion-bottle:hover .bubble:nth-child(2) { animation: riseUp 1.6s ease-in 0.4s    infinite; }
  .potion-bottle:hover .bubble:nth-child(3) { animation: riseUp 1.6s ease-in 0.8s    infinite; }

  @media (prefers-reduced-motion: reduce) {
    .potion-bottle, .bubble { animation: none !important; transition: none !important; }
  }
</style>