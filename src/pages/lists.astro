---
import Layout from '../layouts/BlogPost.astro';

const books = [
  {
    title: "Yolpalas Cinayeti",
    author: "Halide Edip",
    note: "Dedektif kurguyla örülmüş, dönemin İstanbul'unu nefes nefese yaşatan bir roman.",
    stars: 4,
    potion: "/potions/ppotion2.png",
  },
  {
    title: "Matmazel Noraliya'nın Koltuğu",
    author: "Peyami Safa",
    note: "Ruh ve madde arasında sıkışmış bir kadının hikâyesi. Ağır ama bırakamıyorsunuz.",
    stars: 5,
    potion: "/potions/ppotion3.png",
  },
  {
    title: "Gece Savaşları",
    author: "Carlo Ginzburg",
    note: "Mikrotarih ustasının büyülü gerçekçilikle harmanlanmış cadılık araştırması.",
    stars: 4,
    potion: "/potions/ppotion4.png",
  },
];

const movies = [
  {
    title: "Suspiria",
    author: "Luca Guadagnino",
    note: "Orijinalin gölgesinde değil, yanında duran cesur bir yorum. Dans sahnesi unutulmaz.",
    stars: 4,
    potion: "/potions/ppotion5.png",
  },
  {
    title: "Blade",
    author: "Stephen Norrington",
    note: "90'ların en sert aksiyon-korku karışımı. Snipes her karede sahneye hâkim.",
    stars: 4,
    potion: "/potions/ppotion6.png",
  },
  {
    title: "Kız Kardeşler",
    author: "Emin Alper",
    note: "Türk sinemasının nadir sessiz gerilim başarılarından. Atmosfer baştan sona boğucu.",
    stars: 5,
    potion: "/potions/ppotion8.png",
  },
];

function stars(n: number) {
  return "★".repeat(n) + "☆".repeat(5 - n);
}
---

<Layout title="🧙🏻‍♀️🧹🪄🐈‍⬛" noPaper={true}>
  <main class="alchemy-room">

    <h1 class="shelf-title">The Alchemist's Shelf</h1>

    <div class="alchemy-container">
      <div class="bookcase-wrapper">

        <!-- Bookcase frame -->
        <div class="bookcase-frame">
          <!-- Side panels -->
          <div class="side-panel left-panel"></div>
          <div class="side-panel right-panel"></div>
          <!-- Top rail -->
          <div class="top-rail"></div>
          <!-- Bottom base -->
          <div class="base-board"></div>

          <!-- Inner shelves area -->
          <div class="shelves-inner">

            <!-- RAF 1: KİTAPLAR -->
            <div class="shelf-unit">
              <div class="shelf-label-tag"><span>GRIMOIRES &amp; BOOKS</span></div>
              <div class="shelf-surface">
                <div class="potion-grid">
                  {books.map((item) => (
                    <div class="potion-bottle">
                      <div class="bubbles-container">
                        <span class="bubble"></span>
                        <span class="bubble"></span>
                        <span class="bubble"></span>
                      </div>
                      <div class="tooltip-card" role="tooltip">
                        <p class="tc-title">{item.title}</p>
                        <p class="tc-by">{item.author}</p>
                        <p class="tc-note">{item.note}</p>
                        <p class="tc-stars">{stars(item.stars)}</p>
                      </div>
                      <img src={item.potion} class="potion-img-element" alt={item.title} />
                      <span class="bottle-name">{item.title}</span>
                    </div>
                  ))}
                </div>
                <!-- Shelf plank -->
                <div class="shelf-plank">
                  <div class="plank-grain"></div>
                  <div class="plank-edge"></div>
                </div>
              </div>
            </div>

            <!-- RAF 2: FİLMLER -->
            <div class="shelf-unit">
              <div class="shelf-label-tag"><span>VISIONS &amp; CINEMA</span></div>
              <div class="shelf-surface">
                <div class="potion-grid">
                  {movies.map((item) => (
                    <div class="potion-bottle">
                      <div class="bubbles-container">
                        <span class="bubble"></span>
                        <span class="bubble"></span>
                        <span class="bubble"></span>
                      </div>
                      <div class="tooltip-card" role="tooltip">
                        <p class="tc-title">{item.title}</p>
                        <p class="tc-by">{item.author}</p>
                        <p class="tc-note">{item.note}</p>
                        <p class="tc-stars">{stars(item.stars)}</p>
                      </div>
                      <img src={item.potion} class="potion-img-element" alt={item.title} />
                      <span class="bottle-name">{item.title}</span>
                    </div>
                  ))}
                </div>
                <div class="shelf-plank">
                  <div class="plank-grain"></div>
                  <div class="plank-edge"></div>
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>

  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }
  ul, li { list-style: none; }

  /* ── Arka plan ── */
  body:has(.alchemy-room) {
    background-color: transparent !important;
    background-image: none !important;
  }

  body:has(.alchemy-room)::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(rgba(0,0,0,0.70), rgba(0,0,0,0.70)),
      url('/arkaplan3.jpg') center / cover no-repeat;
  }

  /* ── Animasyonlar ── */
  @keyframes spellGlow {
    0%   { text-shadow: 0 0 5px rgba(232,224,224,0.4); opacity: 0.8; }
    50%  { text-shadow: 0 0 15px rgba(255,255,255,0.9); opacity: 1; }
    100% { text-shadow: 0 0 5px rgba(232,224,224,0.4); opacity: 0.8; }
  }

  @keyframes riseUp {
    0%   { opacity: 0;   transform: translateX(-50%) scale(0)   translateY(0px); }
    15%  { opacity: 0.9; transform: translateX(-50%) scale(1)   translateY(-8px); }
    85%  { opacity: 0.4; transform: translateX(-50%) scale(1.1) translateY(-60px); }
    100% { opacity: 0;   transform: translateX(-50%) scale(0.6) translateY(-75px); }
  }

  @keyframes cardAppear {
    from { opacity: 0; transform: translateX(-50%) translateY(6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── Başlık ── */
  .shelf-title {
    display: table;
    margin: 30px auto 40px auto !important;
    padding: 15px 40px !important;
    background: #e4dbb4 !important;
    color: #0f0e0a !important;
    font-family: 'UnifrakturMaguntia', cursive !important;
    font-size: 3rem !important;
    transform: rotate(-1.5deg);
    border: 3px double #d4af37 !important;
    box-shadow: 8px 8px 0px #3e2723 !important;
    text-align: center;
  }

  /* ── Ana alan ── */
  .alchemy-room {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
    max-width: 100% !important;
    margin: 0 auto !important;
    padding: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
  }

  .alchemy-container {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 20px 0 60px;
  }

  /* ═══════════════════════════════════════
     BOOKCASE — CSS-only realistic wooden shelf
     ═══════════════════════════════════════ */

  .bookcase-wrapper {
    position: relative;
  }

  /* Outer frame */
  .bookcase-frame {
    position: relative;
    width: 780px;
    background:
      /* wood grain overlay */
      repeating-linear-gradient(
         91deg,
      transparent 0px,
      transparent 16px,
      rgba(0,0,0,0.06) 16px,
      rgba(0,0,0,0.06) 18px,
      transparent 18px,
      transparent 34px,
      rgba(0,0,0,0.03) 34px,
      rgba(0,0,0,0.03) 35px
    ),
    repeating-linear-gradient(
      180deg,
      transparent 0px,
      transparent 45px,
      rgba(255,255,255,0.02) 45px,
      rgba(255,255,255,0.02) 47px
    ),
    radial-gradient(ellipse 200px 120px at 20% 10%, rgba(80,45,15,0.25), transparent 60%),
    radial-gradient(ellipse 180px 140px at 80% 85%, rgba(60,35,12,0.25), transparent 60%),
    linear-gradient(180deg,
      #24140a 0%,
      #35200f 15%,
      #241408 30%,
      #33200f 50%,
      #22120a 70%,
      #35200f 85%,
      #24140a 100%
    );
  border-radius: 4px 4px 2px 2px;
  box-shadow:
    0 20px 60px rgba(0,0,0,0.85),
    0 8px 20px rgba(0,0,0,0.6),
    inset 0 1px 0 rgba(255,190,110,0.1),
    0 0 0 1px rgba(0,0,0,0.8);
  padding: 28px 28px 36px 28px;
  }

  /* Side panels — thick wooden sides */
  .side-panel {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 28px;
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0px,
        transparent 6px,
        rgba(0,0,0,0.06) 6px,
        rgba(0,0,0,0.06) 7px
      ),
      linear-gradient(90deg,
        #1a0e06 0%,
        #3b2210 30%,
        #4a2c14 60%,
        #2c1a0e 100%
      );
    z-index: 10;
    border-radius: 3px;
  }

  .left-panel {
    left: 0;
    box-shadow: inset -3px 0 8px rgba(0,0,0,0.5), 3px 0 6px rgba(0,0,0,0.4);
  }

  .right-panel {
    right: 0;
    box-shadow: inset 3px 0 8px rgba(0,0,0,0.5), -3px 0 6px rgba(0,0,0,0.4);
  }

  /* Top rail */
  .top-rail {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 28px;
    background:
      repeating-linear-gradient(
        92deg,
        transparent 0px,
        transparent 22px,
        rgba(0,0,0,0.05) 22px,
        rgba(0,0,0,0.05) 24px
      ),
      linear-gradient(180deg,
        #4a2c14 0%,
        #3b2210 40%,
        #2c1a0e 100%
      );
    z-index: 10;
    border-radius: 4px 4px 0 0;
    box-shadow:
      inset 0 3px 6px rgba(255,180,80,0.08),
      0 4px 8px rgba(0,0,0,0.5);
  }

  /* Base board */
  .base-board {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 36px;
    background:
      repeating-linear-gradient(
        92deg,
        transparent 0px,
        transparent 20px,
        rgba(0,0,0,0.06) 20px,
        rgba(0,0,0,0.06) 22px
      ),
      linear-gradient(180deg,
        #2c1a0e 0%,
        #3b2210 30%,
        #4a2c14 60%,
        #1a0e06 100%
      );
    z-index: 10;
    border-radius: 0 0 3px 3px;
    box-shadow:
      inset 0 -2px 4px rgba(0,0,0,0.6),
      0 6px 16px rgba(0,0,0,0.7);
  }

  /* Inner area */
  .shelves-inner {
    position: relative;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 0;
    /* dark back wall */
   background:
    /* dikey panel ayrım çizgileri */
    repeating-linear-gradient(
      90deg,
      rgba(0,0,0,0.4) 0px,
      rgba(0,0,0,0.4) 2px,
      transparent 2px,
      transparent 140px
    ),
    /* ince yatay çizik dokusu */
    repeating-linear-gradient(
      89deg,
      rgba(0,0,0,0.10) 0px,
      transparent 1px,
      transparent 5px
    ),
    /* hafif parlama çizgileri (eski cila kalıntısı) */
    repeating-linear-gradient(
      90deg,
      rgba(255,210,150,0.025) 0px,
      transparent 3px,
      transparent 6px
    ),
    /* nem / patina lekeleri */
    radial-gradient(ellipse 320px 200px at 12% 15%, rgba(90,55,20,0.4), transparent 60%),
    radial-gradient(ellipse 280px 220px at 88% 65%, rgba(70,40,15,0.35), transparent 55%),
    radial-gradient(ellipse 260px 180px at 45% 90%, rgba(50,28,10,0.4), transparent 55%),
    radial-gradient(ellipse 500px 300px at 50% 50%, transparent 40%, rgba(0,0,0,0.55) 100%),
    /* taban ahşap gradyanı — sıcak koyu ceviz */
    linear-gradient(180deg,
      #291706 0%,
      #3a230f 18%,
      #2c1a0b 38%,
      #38220e 58%,
      #241407 78%,
      #1c0f06 100%
    );
  border-radius: 2px;
  padding: 10px 0 0 0;
  box-shadow:
    inset 0 14px 34px rgba(0,0,0,0.6),
    inset 0 -14px 34px rgba(0,0,0,0.55);

  }

  /* ── Shelf unit (raf + label) ── */
  .shelf-unit {
    position: relative;
    padding: 0 0 0 0;
    /* extra top space for tooltips to float freely */
    overflow: visible;
  }

  /* Label tag */
  .shelf-label-tag {
    display: flex;
    justify-content: center;
    padding-top: 18px;
    padding-bottom: 10px;
    position: relative;
    z-index: 5;
  }

  .shelf-label-tag span {
    background: #0d0805;
    color: #d4af37;
    padding: 4px 18px;
    border: 1px solid rgba(212,175,55,0.5);
    font-family: 'Crimson Text', serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    box-shadow:
      0 0 12px rgba(212,175,55,0.15),
      inset 0 0 8px rgba(0,0,0,0.5);
  }

  /* Shelf surface: holds potions + plank */
  .shelf-surface {
    position: relative;
    overflow: visible;
    /* room above for tooltips */
    padding-top: 10px;
  }

  /* ── Potion grid ── */
  .potion-grid {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 28px;
    width: 100%;
    overflow: visible;
    /* sits above the plank; plank height is ~22px */
    padding-bottom: 11px;
    padding-top: 8px;
    position: relative;
    z-index: 6;
  }

  /* ── Shelf plank ── */
  .shelf-plank {
    position: relative;
    height: 22px;
    margin: 0 10px;
    border-radius: 2px;
    background:
       repeating-linear-gradient(
      91deg,
      transparent 0px,
      transparent 26px,
      rgba(0,0,0,0.06) 26px,
      rgba(0,0,0,0.06) 28px
    ),
    repeating-linear-gradient(
      89deg,
      rgba(0,0,0,0.07) 0px,
      transparent 1px,
      transparent 3px
    ),
    radial-gradient(ellipse 60px 10px at 30% 50%, rgba(30,15,5,0.3), transparent 70%),
    radial-gradient(ellipse 80px 10px at 75% 50%, rgba(30,15,5,0.25), transparent 70%),
    linear-gradient(180deg,
      #4a2e18 0%,
      #654024 14%,
      #573320 32%,
      #6b4526 50%,
      #4c2e18 70%,
      #35200f 88%,
      #241408 100%
    );
  box-shadow:
    inset 0 2px 3px rgba(255,180,100,0.12),
    0 6px 14px rgba(0,0,0,0.75),
    0 3px 6px rgba(0,0,0,0.5);
  z-index: 4;
  }

  .plank-grain {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      95deg,
      transparent 0px,
      transparent 8px,
      rgba(255,255,255,0.018) 8px,
      rgba(255,255,255,0.018) 9px
    );
    border-radius: 2px;
  }

  /* Front edge of the plank — 3D lip */
  .plank-edge {
    position: absolute;
    bottom: -8px;
    left: 0;
    right: 0;
    height: 8px;
    background: linear-gradient(180deg,
      #3a1e0a 0%,
      #2a1406 60%,
      #1a0c04 100%
    );
    border-radius: 0 0 3px 3px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.6);
  }

  /* ── İksir şişesi ── */
  .potion-bottle {
    position: relative;
    width: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    /* tooltip floats upward — needs overflow visible on parents */
    overflow: visible;
    cursor: pointer;
    transition: transform 0.3s ease;
    z-index: 5;
  }

  .potion-bottle:hover {
    transform: scale(1.12) translateY(-10px);
    z-index: 50;
  }

  /* ── PNG görseli ── */
  .potion-img-element {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 2;
    margin-bottom: -50px;   /* PNG içindeki alt boşluğu telafi eder */
  filter: drop-shadow(0 8px 12px rgba(0,0,0,0.7));
  transition: filter 0.3s ease;

  }

  .potion-bottle:hover .potion-img-element {
    filter: drop-shadow(0 0 16px rgba(212,175,55,0.85));
  }

  /* ── Şişe altı isim ── */
  .bottle-name {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: 'Crimson Text', serif;
    font-size: 0.72rem;
    font-weight: 600;
    color: #e0cfa0;
    text-align: center;
    line-height: 1.2;
    max-width: 90px;
    margin-top: 5px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.9);
    animation: spellGlow 3s infinite ease-in-out;
    position: relative;
    z-index: 2;
  }

  /* ── Tooltip kart ──
     Rendered BEFORE the img in DOM so it stacks above
     via z-index without needing a portal.
     Positioned above the bottle top.
  ── */
  .tooltip-card {
    display: none;
    position: absolute;
    /* anchor to bottom of the tooltip-card itself = just above bottle */
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    padding: 12px 14px;
    background: #1a1008;
    border: 1px solid rgba(212,175,55,0.45);
    border-radius: 8px;
    box-shadow:
      0 12px 36px rgba(0,0,0,0.9),
      0 0 0 1px rgba(212,175,55,0.1);
    pointer-events: none;
    /* must be above everything */
    z-index: 999;
    font-family: 'Crimson Text', serif;
  }

  /* Arrow pointing down */
  .tooltip-card::after {
    content: "";
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 7px solid transparent;
    border-top-color: rgba(212,175,55,0.45);
  }

  .potion-bottle:hover .tooltip-card {
    display: block;
    animation: cardAppear 0.18s ease;
  }

  .tc-title {
    font-weight: 600;
    font-size: 0.88rem;
    color: #e8d8b0;
    line-height: 1.3;
    margin-bottom: 3px;
  }

  .tc-by {
    font-size: 0.68rem;
    font-style: italic;
    color: #9a7850;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(212,175,55,0.2);
    margin-bottom: 8px;
  }

  .tc-note {
    font-size: 0.72rem;
    font-style: italic;
    color: #c4b090;
    line-height: 1.55;
  }

  .tc-stars {
    margin-top: 8px;
    font-size: 0.74rem;
    color: #d4af37;
    letter-spacing: 1px;
  }

  /* ── Baloncuklar ── */
  .bubbles-container {
    position: absolute;
    top: 6%;
    left: 50%;
    width: 50px;
    height: 20px;
    z-index: 30;
    pointer-events: none;
    overflow: visible;
  }

  .bubble {
    position: absolute;
    bottom: 0;
    border-radius: 50%;
    opacity: 0;
    transform: translateX(-50%) scale(0);
    background: radial-gradient(circle at 35% 35%, rgba(255,210,230,0.95), rgba(255,140,190,0.7));
    border: 1px solid rgba(255,180,220,0.8);
  }

  .bubble:nth-child(1) { left: 8px;  width: 7px;  height: 7px; }
  .bubble:nth-child(2) { left: 22px; width: 10px; height: 10px; }
  .bubble:nth-child(3) { left: 36px; width: 6px;  height: 6px; }

  .potion-bottle:hover .bubble:nth-child(1) { animation: riseUp 1.6s ease-in 0s      infinite; }
  .potion-bottle:hover .bubble:nth-child(2) { animation: riseUp 1.6s ease-in 0.4s    infinite; }
  .potion-bottle:hover .bubble:nth-child(3) { animation: riseUp 1.6s ease-in 0.8s    infinite; }

  @media (prefers-reduced-motion: reduce) {
    .potion-bottle, .bubble { animation: none !important; transition: none !important; }
  }
</style>