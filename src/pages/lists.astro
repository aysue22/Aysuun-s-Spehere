---
import Layout from '../layouts/BlogPost.astro'; // Layout dosyanın adından emin ol


const books = [
  { title: "Mülksüzler", author: "Ursula K. Le Guin" },
  { title: "Cadılar", author: "Roald Dahl" },
  { title: "Gece Savaşları: 16. ve 17. Yüzyıllarda Cadılık ve Tarım Kültleri", author: "Carlo Ginzburg" }
];

const movies = [
  { title: "Suspiria", director: "Luca Guadagnino" },
  { title: "The Witch", director: "Robert Eggers" },
  { title: "Stalker", director: "Andrey Tarkovski" }
];
---

<Layout title="Potion Shelf">
  <main class="alchemy-room">
    <h1 class="shelf-title">The Alchemist's Shelf</h1>

    <div class="shelf">
      <h2 class="shelf-label">Magic Parchments (Books)</h2>
      <div class="potion-grid">
        {books.map((book) => (
          <div class="potion-bottle book-potion">
            <div class="potion-liquid"></div>
            <div class="potion-label">
              <span class="title">{book.title}</span>
              <span class="info">{book.author}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="shelf">
      <h2 class="shelf-label">Visual Rituals (Movies)</h2>
      <div class="potion-grid">
        {movies.map((movie) => (
          <div class="potion-bottle movie-potion">
            <div class="potion-liquid"></div>
            <div class="potion-label">
              <span class="title">{movie.title}</span>
              <span class="info">{movie.director}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style is:global>
.shelf-title, h1 {
    background: #1a1a1a !important; /* Siyah fanzin etiketi */
    color: #d4af37 !important;    /* Altın sarısı yazı */
    padding: 15px 30px !important;
    display: table !important;    /* Etiketin yazı kadar olması için */
    margin: 40px auto !important; /* Ortalar */
    
    font-family: 'UnifrakturMaguntia', cursive !important;
    font-size: 3rem !important;
    
    /* El yapımı/Yırtık kağıt efekti */
    transform: rotate(-1.5deg);
    border: 3px double #d4af37 !important;
    box-shadow: 8px 8px 0px #3e2723 !important;
    
    position: relative;
    z-index: 20;
  }

  /* "Kadim Zamanlar" gibi tanıtım/alt başlık yazıları için */
  .intro-text, .description, p {
    background: #fdfaf1 !important; /* Parşömen beyazı etiket */
    color: #82a218 !important;    /* Siyah yazı */
    padding: 10px 20px !important;
    display: table !important;
    margin: 10px auto 40px auto !important;
    
    font-family: 'Crimson Text', serif !important;
    font-style: italic;
    font-size: 1.2rem !important;
    
    /* Zıt tarafa yamultalım ki salaş dursun */
    transform: rotate(1deg);
    border: 1px solid #3e2723 !important;
    box-shadow: 4px 4px 0px rgba(0,0,0,0.5) !important;
    
    position: relative;
    z-index: 15;
  }
 body {
    background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/arkaplan3.jpg') !important;
    background-size: cover !important;
    background-position: center !important;
    background-attachment: fixed !important;
    background-color: #2d3e2d; /* Resim yüklenmezse diye yedek renk */
  }

  /* Sayfanın ortasındaki beyaz kutu resmi kapatmasın diye şeffaf yapıyoruz */
  main, .container, .alchemy-room {
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
  }
    
    background-size: cover; /* Resmi tüm ekrana yayar */
    background-position: center; /* Resmi ortalar */
    background-attachment: fixed; /* Sayfa kayarken resim sabit kalır (Mistik bir derinlik katar) */
    
    padding: 40px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;

  .alchemy-room { background: #fdfaf1; padding: 40px; min-height: 100vh; }
  .shelf-title { font-family: 'UnifrakturMaguntia', cursive; text-align: center; font-size: 3rem; color: #1a331a; margin-bottom: 60px; }
  .shelf { margin-bottom: 120px; border-bottom: 15px solid #6b6907; padding-bottom: 10px; position: relative; }
  .shelf-label { font-family: 'Crimson Text', serif; font-style: italic; font-size: 1.5rem; color: #d4af37; text-align: center; margin-bottom: 20px; }
  .potion-grid { display: flex; justify-content: space-around; align-items: flex-end; padding: 20px; flex-wrap: wrap; gap: 40px; }
  
  .potion-bottle { width: 80px; height: 120px; background: rgba(255, 255, 255, 0.2); border: 2px solid #3e2723; position: relative; border-radius: 20px 20px 10px 10px; transition: transform 0.3s ease; }
  .book-potion { height: 140px; border-radius: 5px 5px 10px 10px; }
  .book-potion .potion-liquid { background: #4cc14c; height: 70%; bottom: 0; position: absolute; width: 100%; border-radius: 0 0 8px 8px; }
  .movie-potion { width: 100px; height: 100px; border-radius: 50% 50% 10px 10px; }
  .movie-potion .potion-liquid { background: #cb7070; height: 60%; bottom: 0; position: absolute; width: 100%; border-radius: 0 0 50% 50%; }

  .potion-label { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #e9dcc9; border: 1px solid #3e2723; padding: 5px; width: 90%; text-align: center; font-family: 'Crimson Text', serif; box-shadow: 2px 2px 0px rgba(0,0,0,0.2); z-index: 10; }
  .potion-label .title { display: block; font-weight: bold; font-size: 0.75rem; color: #1a1a1a; }
  .potion-label .info { font-size: 0.6rem; color: #3e2723; display: block; }
  .potion-bottle:hover { transform: scale(1.1) translateY(-10px); }
</style>