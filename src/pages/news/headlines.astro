---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
export const transitionEnabled = true;

const headlines = [
	{
		title: "Femicide is being classic daily life news.",
		summary: `Women are being killed by men they have just met. In recent days in Istanbul, two women were found murdered and decapitated. In both cases, the suspects claimed they had \u201cmet, fallen in love, argued, and then killed\u201d the victims. These statements are repeatedly reproduced by the media and legal authorities, allowing perpetrators to shape the public narrative. By centering the words of \u201ccinayet zanl\u0131lar\u0131\u201d, the justice system and the press indirectly criminalize the victims\u2019 character and legitimize misogynistic assumptions\u2014suggesting that a woman\u2019s behavior can justify violence against her. This reflects a deeper structural failure in legal procedures and a political gap created after Turkey\u2019s withdrawal from the Istanbul Convention. The absence of effective protective mechanisms continues to cost women their lives.`,
		whyItMatters: "The solution is clear: Return to the Istanbul Convention. Enforce Law No. 6284.",
		link: "https://haber.sol.org.tr/haber/sislide-kadin-cinayeti-cop-konteynerlerini-kadinlara-tabut-yapan-siddet-iktidarinizi"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`HEADLINES | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet">
	</head>
	<body class="headlines-body">
		<Header />
		<main class="headlines-main">

			<h1 class="graffiti-title">HEADLINES</h1>

			<section class="news-stream">
				{headlines.map((item) => (
					<article class="news-sheet">
						<h2 class="sheet-title">{item.title}</h2>
						<p class="sheet-text">{item.summary}</p>
						<div class="sheet-impact">
							<span class="impact-label">WHY IT MATTERS</span>
							<p class="impact-content">{item.whyItMatters}</p>
						</div>
						<a href={item.link} class="source-btn">&gt;&gt; LEAK TO SOURCE</a>
					</article>
				))}
			</section>

		</main>
		<Footer />
	</body>
</html>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
	}

	/* ── ARKA PLAN ── */
	.headlines-body {
		background-color: #d10000 !important;
		background-image:
			linear-gradient(rgba(0,0,0,0.1) 2px, transparent 2px),
			linear-gradient(90deg, rgba(0,0,0,0.1) 2px, transparent 2px) !important;
		background-size: 40px 40px;
		margin: 0;
	}

	/* ── ANA KAPSAYICI ── */
	.headlines-main {
		width: 90%;
		max-width: 800px;
		margin: 80px auto 60px;
		padding: 0;
	}

	/* ── GRAFFİTİ BAŞLIK ── */
	.graffiti-title {
		font-family: 'Permanent Marker', cursive !important;
		font-size: clamp(3rem, 12vw, 6rem);
		color: #000;
		text-align: center;
		text-transform: uppercase;
		margin-bottom: clamp(1.5rem, 5vw, 3rem);
		transform: rotate(-3deg);
		text-shadow: 4px 4px 0px #bc95d4;
		line-height: 1;
	}

	/* ── HABER KARTI ── */
	.news-sheet {
		background: #ffffff !important;
		color: #000 !important;
		padding: clamp(20px, 5vw, 40px);
		margin-bottom: clamp(30px, 8vw, 60px);
		border: 5px solid #000;
		box-shadow: 15px 15px 0px #000;
		position: relative;
		transform: rotate(1deg);
	}

	.sheet-title {
		font-family: 'Permanent Marker', cursive !important;
		font-size: clamp(1.4rem, 5vw, 2.5rem);
		line-height: 1.2;
		margin-bottom: 20px;
		color: #d10000;
		border-bottom: 4px solid #bc95d4;
		padding-bottom: 10px;
	}

	.sheet-text {
		font-family: 'Courier New', Courier, monospace;
		font-size: clamp(0.9rem, 2.5vw, 1.25rem);
		font-weight: bold;
		line-height: 1.6;
		margin-bottom: 30px;
	}

	/* ── WHY IT MATTERS ── */
	.sheet-impact {
		border: 3px solid #000;
		padding: 20px;
		padding-top: 28px;
		background: #f0f0f0;
		position: relative;
		margin-bottom: 10px;
	}

	.impact-label {
		position: absolute;
		top: -14px;
		left: 10px;
		background: #bc95d4;
		color: #000;
		font-weight: 900;
		padding: 2px 10px;
		font-family: 'Courier New', monospace;
		font-size: clamp(0.7rem, 2vw, 0.9rem);
		border: 2px solid #000;
		white-space: nowrap;
	}

	.impact-content {
		font-family: 'Courier New', monospace;
		font-size: clamp(0.85rem, 2.2vw, 1rem);
		font-weight: 900;
		text-transform: uppercase;
		line-height: 1.5;
		margin: 0;
	}

	/* ── BUTON ── */
	.source-btn {
		display: inline-block;
		margin-top: 25px;
		background: #000;
		color: #fff !important;
		padding: 10px 20px;
		font-weight: 900;
		text-decoration: none;
		font-family: 'Courier New', monospace;
		font-size: clamp(0.85rem, 2.5vw, 1rem);
		transition: background 0.2s, color 0.2s;
	}

	.source-btn:hover {
		background: #bc95d4;
		color: #000 !important;
	}

	/* ── MOBİL BREAKPOINT (≤600px) ── */
	@media (max-width: 600px) {
		.headlines-main {
			margin: 60px auto 40px;
		}

		.graffiti-title {
			transform: rotate(-1.5deg);
		}

		.news-sheet {
			transform: rotate(0deg);   /* Yamukluğu kaldır */
			box-shadow: 8px 8px 0px #000;
		}

		.impact-label {
			white-space: normal;
			max-width: 75%;
			line-height: 1.3;
		}

		.source-btn {
			display: block;            /* Tam genişlik buton */
			text-align: center;
		}
	}

	/* ── HAREKET HASSAS ── */
	@media (prefers-reduced-motion: reduce) {
		.news-sheet,
		.graffiti-title {
			transform: none;
		}
	}
</style>