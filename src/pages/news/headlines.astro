---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
export const transitionEnabled = true; // Sayfa geçişlerini zorla

const headlines = [
	{
		title: "Femicide is being classic daily life news.",
		summary: "Women are being killed by men they have just met. In recent days in Istanbul, two women were found murdered and decapitated. In both cases, the suspects claimed they had “met, fallen in love, argued, and then killed” the victims.These statements are repeatedly reproduced by the media and legal authorities, allowing perpetrators to shape the public narrative. By centering the words of “cinayet zanlıları”, the justice system and the press indirectly criminalize the victims’ character and legitimize misogynistic assumptions—suggesting that a woman’s behavior can justify violence against her.This reflects a deeper structural failure in legal procedures and a political gap created after Turkey’s withdrawal from the Istanbul Convention. The absence of effective protective mechanisms continues to cost women their lives.",
		whyItMatters: "The solution is clear: Return to the Istanbul Convention. Enforce Law No. 6284.",
		link: "https://haber.sol.org.tr/haber/sislide-kadin-cinayeti-cop-konteynerlerini-kadinlara-tabut-yapan-siddet-iktidarinizi"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`HEADLINES | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet">
	</head>
	<body class="headlines-body">
		<Header />
		<main class="headlines-radical">
			
			<div class="header-area">
				<h1 class="graffiti-title">HEADLINES</h1>
			</div>

			<section class="news-stream">
				{headlines.map((item) => (
					<article class="news-sheet">
						<h2 class="sheet-title">{item.title}</h2>

						<div class="sheet-body">
							<p class="sheet-text">{item.summary}</p>
							
							<div class="sheet-impact">
								<span class="impact-label">WHY IT MATTERS</span>
								<p class="impact-content">{item.whyItMatters}</p>
							</div>

							<div class="sheet-footer">
								<a href={item.link} class="source-btn">>> LEAK TO SOURCE</a>
							</div>
						</div>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	/* 1. ARKA PLAN: FULL KIRMIZI */
	.headlines-body {
		background-color: #d10000 !important; /* Canlı, agresif kırmızı */
		background-image: 
			linear-gradient(rgba(0,0,0,0.1) 2px, transparent 2px),
			linear-gradient(90deg, rgba(0,0,0,0.1) 2px, transparent 2px) !important;
		background-size: 40px 40px; /* Kağıt dokusu hissi için hafif kareler */
		margin: 0;
	}

	.headlines-radical {
		max-width: 800px;
		margin: 40px auto;
		padding: 20px;
	}

	/* 2. GRAFFITI BAŞLIK */
	.graffiti-title {
		font-family: 'Permanent Marker', cursive !important;
		font-size: 6rem;
		color: #000;
		text-align: center;
		text-transform: uppercase;
		margin-bottom: 2rem;
		transform: rotate(-3deg);
		text-shadow: 4px 4px 0px #bc95d4; /* MOR DETAY: Gölgede saklı */
	}

	/* 3. HABER SEKMESİ: BEYAZ KAĞIT EFEKTİ */
	.news-sheet {
		background: #ffffff !important; /* Yazıların okunması için saf beyaz */
		color: #000 !important;
		padding: 40px;
		margin-bottom: 60px;
		border: 5px solid #000;
		box-shadow: 15px 15px 0px #000;
		position: relative;
		transform: rotate(1deg); /* Elle yapıştırılmış gibi hafif yamuk */
	}

	.sheet-title {
		font-family: 'Permanent Marker', cursive !important;
		font-size: 2.5rem;
		line-height: 1;
		margin-bottom: 20px;
		color: #d10000; /* Başlıkta da kırmızı vurgu */
		border-bottom: 4px solid #bc95d4; /* MOR DETAY: İnce alt çizgi */
		padding-bottom: 10px;
	}

	.sheet-text {
		font-family: 'Courier New', Courier, monospace;
		font-size: 1.25rem;
		font-weight: bold;
		line-height: 1.4;
		margin-bottom: 30px;
	}

	/* 4. WHY IT MATTERS ALANI */
	.sheet-impact {
		border: 3px solid #000;
		padding: 20px;
		background: #f0f0f0;
		position: relative;
	}

	.impact-label {
		position: absolute;
		top: -15px;
		left: 10px;
		background: #bc95d4; /* MOR DETAY: Etiket rengi */
		color: #000;
		font-weight: 900;
		padding: 2px 10px;
		font-family: 'Courier New', monospace;
		border: 2px solid #000;
	}

	.impact-content {
		font-family: 'Courier New', monospace;
		font-weight: 900;
		text-transform: uppercase;
		margin: 0;
	}

	/* 5. BUTON */
	.source-btn {
		display: inline-block;
		margin-top: 25px;
		background: #000;
		color: #fff !important;
		padding: 10px 20px;
		font-weight: 900;
		text-decoration: none;
		font-family: 'Courier New', monospace;
		transition: 0.2s;
	}

	.source-btn:hover {
		background: #bc95d4; /* MOR DETAY: Hover efekti */
		color: #000 !important;
	}
</style>