---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const reports = [
	{
		title: "PROTESTONUN ESTETİĞİ VE SÜREKLİLİK SORUNU",
		intro: "Sokaktaki eylemin performatif gücü ile siyasal örgütlenme arasındaki kopukluk, modern protesto kültürünün en büyük açmazı haline geldi.",
		analysis: "Aktörlerin yatay örgütlenme ısrarı, dikey bir devlet aygıtı karşısında rıza üretimini kıramıyor. Karşılaştırmalı baktığımızda, 90'lar işçi hareketindeki 'sınıfsal blok' bugün yerini 'estetik bir itiraza' bırakmış durumda.",
		theory: "Gramsci: Hegemonya ve Mevzi Savaşı | Foucault: Disipliner İktidar",
		result: "Sonuç olarak; sokak, teorik bir altyapıyla birleşmediği sürece sadece geçici bir parlamadan ibaret kalıyor.",
		link: "#"
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`REPORTS | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet">
	</head>
	<body class="reports-body">
		<Header />
		<main class="reports-radical">
			
			<div class="header-area">
				<h1 class="graffiti-title">REPORTS</h1>
			</div>

			<section class="analysis-stream">
				{reports.map((report) => (
					<article class="report-sheet">
						<h2 class="report-main-title">{report.title}</h2>

						<div class="report-content">
							<div class="report-section">
								<span class="label-black">GİRİŞ / ÇERÇEVE</span>
								<p class="report-text">{report.intro}</p>
							</div>

							<div class="report-section">
								<span class="label-black">ANALİZ / AKTÖRLER</span>
								<p class="report-text">{report.analysis}</p>
							</div>

							<div class="theory-connection">
								<span class="theory-label">TEORİK BAĞ</span>
								<p class="theory-text">{report.theory}</p>
							</div>

							<div class="report-section">
								<span class="label-red">KISA SONUÇ</span>
								<p class="report-text bold-text">{report.result}</p>
							</div>

							<div class="report-footer">
								<a href={report.link} class="archive-btn">>> ARŞİVE İN / DİPNOTLAR</a>
							</div>
						</div>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style is:inline is:global>
	/* 1. ARKA PLAN: AGRESİF KIRMIZI (Headlines ile aynı) */
	.reports-body {
		background-color: #d10000 !important;
		background-image: 
			linear-gradient(rgba(0,0,0,0.15) 2px, transparent 2px),
			linear-gradient(90deg, rgba(0,0,0,0.15) 2px, transparent 2px) !important;
		background-size: 50px 50px;
		margin: 0;
	}

	.reports-radical {
		max-width: 850px;
		margin: 40px auto;
		padding: 20px;
	}

	.graffiti-title {
		font-family: 'Permanent Marker', cursive !important;
		font-size: clamp(3rem, 10vw, 6rem);
		color: #000;
		text-align: center;
		text-transform: uppercase;
		margin-bottom: 2rem;
		transform: rotate(2deg); /* Zıt yöne eğim */
		text-shadow: 4px 4px 0px #bc95d4; /* MOR DETAY */
	}

	/* 2. REPORT SEKMESİ: SARARMIŞ ARŞİV KAĞIDI */
	.report-sheet {
		background: #fdf6e3 !important; /* Hafif sararmış, "vintage" kağıt rengi */
		color: #1a1a1a !important;
		padding: 50px;
		margin-bottom: 80px;
		border: 4px solid #000;
		box-shadow: 20px 20px 0px #000;
		position: relative;
		transform: rotate(-0.5deg);
	}

	.report-main-title {
		font-family: 'Permanent Marker', cursive !important;
		font-size: 2.2rem;
		line-height: 1.1;
		margin-bottom: 30px;
		color: #000;
		text-transform: uppercase;
		border-bottom: 8px solid #bc95d4; /* Kalın MOR alt çizgi */
		padding-bottom: 10px;
	}

	/* 3. İÇERİK YAPISI */
	.report-section {
		margin-bottom: 25px;
	}

	.label-black {
		background: #000;
		color: #fdf6e3;
		font-family: 'Courier New', monospace;
		font-weight: 900;
		padding: 2px 8px;
		font-size: 0.8rem;
		display: inline-block;
		margin-bottom: 10px;
	}

	.label-red {
		background: #d10000;
		color: #fff;
		font-family: 'Courier New', monospace;
		font-weight: 900;
		padding: 2px 8px;
		font-size: 0.8rem;
		display: inline-block;
		margin-bottom: 10px;
	}

	.report-text {
		font-family: 'Georgia', serif; /* Analiz metni olduğu için daha okunaklı bir serif */
		font-size: 1.15rem;
		line-height: 1.6;
		margin: 0;
	}

	.bold-text {
		font-weight: bold;
	}

	/* 4. TEORİK BAĞ (KRİTİK ALAN) */
	.theory-connection {
		border: 2px dashed #bc95d4; /* MOR Kesik çizgi */
		padding: 20px;
		background: rgba(188, 149, 212, 0.1);
		margin: 30px 0;
		position: relative;
	}

	.theory-label {
		position: absolute;
		top: -12px;
		right: 15px;
		background: #bc95d4; /* MOR ETİKET */
		color: #000;
		font-weight: 900;
		padding: 2px 10px;
		font-size: 0.75rem;
		font-family: 'Courier New', monospace;
	}

	.theory-text {
		font-family: 'Courier New', monospace;
		font-weight: bold;
		font-style: italic;
		margin: 0;
		color: #3d1a4d;
	}

	/* 5. BUTON */
	.archive-btn {
		display: inline-block;
		margin-top: 30px;
		background: #000;
		color: #fff !important;
		padding: 12px 24px;
		font-weight: 900;
		text-decoration: none;
		font-family: 'Courier New', monospace;
		transition: 0.2s;
	}

	.archive-btn:hover {
		background: #d10000;
		transform: translate(-5px, -5px);
		box-shadow: 5px 5px 0px #bc95d4;
	}
</style>