---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getCollection('blog')).sort(
	(a, b) =>
	new Data(b.data.pubDate).getTime() -
	new Data(a.data.pubDate).getTime() 
);


---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header /> 
		<main>
			<section class="zine-section">
                <div class="anarchist-banner">
                    "Resistence starts with fighting against ıgnorant peopless and ıgnorance is not a personal failure, but a structural outcome. "
                </div>

				<ul class="post-list">
					{
						posts.map((post) => {
							const cleanSlug = String(post.slug || post.id).replace('.md', '');
							return (
								<li class="zine-card">
									<a href={`/blog/${cleanSlug}/`}>
										<div class="image-wrapper">
                                            {post.data.heroImage && (
                                                <img 
                                                    src={post.data.heroImage} 
                                                    alt={post.data.title} 
                                                    class="zine-image"
                                                />
                                            )}
                                        </div>
										<h4 class="zine-title">{post.data.title}</h4>
										<p class="zine-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	/* 1. KOYU MOR ARKA PLAN */
	html {
		background-color: #1a0a24 !important; 
		background-image: radial-gradient(rgba(255,0,0,0.05) 1px, transparent 1px) !important; /* Çok hafif kırmızı noktalar */
		background-size: 20px 20px;
	}

	body {
		background: transparent !important;
		margin: 0;
	}

    /* 2. ANARŞİST SLOGAN BANNER (Kızıl ve Siyah) */
    .anarchist-banner {
        background-color: #8b0000 !important; /* Koyu Kan Kırmızısı */
        color: #000 !important; /* Siyah Yazı */
        font-family: 'Courier New', Courier, monospace;
        font-weight: bold;
        padding: 10px;
        text-align: center;
        text-transform: uppercase;
        font-size: 0.9rem;
        margin-bottom: 3rem;
        transform: rotate(-1deg);
        box-shadow: 5px 5px 0px #000;
        border: 1px solid #000;
    }

	/* 3. DAKTİLO STİLİ BAŞLIKLAR */
	.zine-title {
		font-family: 'Courier New', Courier, monospace !important; /* Daktilo Fontu */
		font-weight: bold !important;
		color: #f0e6d2 !important; /* Krem */
		font-size: 1.8rem;
		text-transform: uppercase;
		margin: 15px 0 5px 0;
        line-height: 1.2;
        /* Marker ile çizilmiş gibi efekt */
        display: inline;
        background-color: #000;
        padding: 4px 10px;
        box-decoration-break: clone;
	}

    .zine-card {
        margin-bottom: 4rem;
        list-style: none;
        transition: transform 0.2s;
    }

    .zine-card:hover {
        transform: scale(1.02) rotate(1deg);
    }

    /* 4. KOLAJ STİLİ RESİMLER */
    .image-wrapper {
        background-color: #000;
        padding: 10px;
        border: 1px solid #3d1a4d;
        box-shadow: 2px 2px 0px #8b0000; /* Kızıl gölge */
        transform: rotate( 0.5deg);
    }

    

	.zine-date {
		color: #8b0000 !important; /* Kırmızı tarih */
		font-family: 'Courier New', monospace;
		font-weight: bold;
        margin-top: 10px;
        display: block;
	}

    .zine-section {
        max-width: 700px;
        margin: 50px auto;
        padding: 0 20px;
    }

	li a {
		text-decoration: none;
	}
</style>