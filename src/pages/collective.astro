---
import BlogPost from '../layouts/BlogPost.astro';
---

<BlogPost
	title="Collective"
	description="A curated space for voices, works, and practices I resonate with."
>
	<section class="collective-intro">
		<p class="manifesto-text">
			<em>Collective is not a guest post dump.</em> It is a curated space for voices, works and practices I resonate with.
		</p>
	</section>

	<section class="selection-criteria">
		<h4>Selection Criteria</h4>
		<ul>
			<li>Independent or non-institutional production</li>
			<li>Ethical alignment (feminism, ecology, social justice)</li>
			<li>Process over virality</li>
		</ul>
	</section>

	<hr class="thin-line" />

	<div class="collective-grid">
		<div class="collective-card">
			<div class="card-header">
				<span class="medium-tag">Publishing · Berlin</span>
			</div>
			<h3 class="project-name">Luna Press</h3>
			<p class="short-desc">Independent feminist publishing.</p>
			<a href="/collective/luna-press" class="read-link">→ Read</a>
		</div>

		</div>

	<section class="submissions">
		<p>This space is curated. You may suggest your work, but inclusion is not guaranteed.</p>
		<a href="/contact" class="submit-btn">Open Submissions</a>
	</section>

</BlogPost>

<style is:global> 
  /* "is:global" eklemek Astro'nun bu stili tüm sayfaya yaymasını sağlar */
  body {
    background-image: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), 
                      url('/images/arkaplan7.jpg') !important;
    background-size: cover !important;
    background-position: center !important;
    background-attachment: fixed !important;
    background-color: #1a1a1a; /* Resim yüklenmezse diye yedek renk */
  }

	.manifesto-text {
		font-size: 1.4rem;
		line-height: 1.6;
		font-family: 'Georgia', serif; /* Editorial hissi için serif */
		margin-bottom: 2rem;
	}
	.selection-criteria {
		font-size: 0.9rem;
		opacity: 0.8;
		border-left: 1px solid #bc95d4;
		padding-left: 20px;
		margin-bottom: 3rem;
	}
	.collective-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 2rem;
	}
	.collective-card {
		border-bottom: 1px solid #333;
		padding-bottom: 1.5rem;
		transition: all 0.3s ease;
	}
	.collective-card:hover {
		border-color: #bc95d4;
	}
	.medium-tag {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: #888;
	}
	.project-name {
		margin: 0.5rem 0;
		font-weight: 500;
	}
	.read-link {
		font-size: 0.9rem;
		text-decoration: none;
		color: #bc95d4;
	}
    
</style>