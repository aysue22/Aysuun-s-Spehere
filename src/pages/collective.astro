---
import BlogPost from '../layouts/BlogPost.astro';
---

<BlogPost
	title="Collective"
	description="A curated space for voices, works, and practices I resonate with."
>
	<div class="collective-page-container">
  
		<section class="collective-intro">
			<h1 class="project-name">Collective</h1> 
			<p class="manifesto-text">
				<span class="short-desc">Collective is not a guest post dump.</span> <br>
				<span class="label-manifesto">
					It is a curated space for voices, works and practices I resonate with.
				</span>
			</p>
		</section>

		<section class="selection-criteria">
			<h4 class="medium-tag">Selection Criteria</h4>
			<ul class="criteria-list">
				<li><span class="label-cream">Independent or non-institutional production</span></li>
				<li><span class="label-cream">Ethical alignment (feminism, ecology, social justice)</span></li>
				<li><span class="label-cream">Process over virality</span></li>
			</ul>
		</section>

		<hr class="thin-line" />

		<div class="collective-grid">
			<div class="collective-card">
				<div class="card-header">
					<span class="medium-tag">Publishing · Berlin</span>
				</div>
				<h3 class="project-name">Luna Press</h3>
				<p class="short-desc">Independent feminist publishing.</p>
				<a href="/collective/luna-press" class="read-link">→ Read</a>
			</div>
		</div>

		<section class="submissions">
			<p>This space is curated. You may suggest your work, but inclusion is not guaranteed.</p>
			<a href="/contact" class="submit-btn">Open Submissions</a>
		</section>
	</div>
</BlogPost>

<style is:global> 
	html::before {
		content: "";
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1000;
		background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
		                  url('/bg-v1.jpg');
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
	}

	h1, h2, h3, h4, h5, h6, p, div {
		background-color: transparent !important;
	}

	h1, h2, h3, h4, h5, h6, p {
		margin: 0;
		padding: 0;
	}

	/* ── KREM KAĞIT BLOK ── */
	main, article, .prose, .container {
		background-color: #f0e6d2 !important;
		color: #1a1a1a !important;
		
		/* Fluid padding: mobilde 1rem, masaüstünde 2rem */
		padding: clamp(1rem, 4vw, 2rem) !important;
		
		/* Kenarlardan taşmasın */
		width: 90% !important;
		max-width: 850px !important;
		margin: clamp(1.5rem, 5vw, 2rem) auto !important;
		
		box-shadow: 10px 10px 0px #000;
		border: 2px solid #000;
		box-sizing: border-box !important;
	}

	/* ── İÇERİK KAPSAYICISI ── */
	.collective-page-container {
		width: 100%;
		box-sizing: border-box;
	}

	/* ── BAŞLIKLAR ── */
	.project-name {
		display: table;
		background-color: #bc95d4 !important;
		color: #1a1a1a !important;
		padding: 0.2rem 0.6rem;
		font-family: 'Georgia', serif;
		font-size: clamp(1.2rem, 4vw, 1.8rem); /* Fluid font */
		box-shadow: 4px 4px 0px #000;
		margin: 1rem 0;
		/* Taşmayı önle */
		max-width: 100%;
		word-break: break-word;
	}

	.medium-tag {
		background-color: #1a1a1a !important;
		color: #f0e6d2 !important;
		padding: 0.2rem 0.6rem;
		font-size: 0.8rem;
		font-weight: bold;
		text-transform: uppercase;
		display: inline-block;
	}

	.short-desc {
		background-color: #bc95d4;
		color: #1a1a1a !important;
		padding: 0.3rem 0.6rem;
		display: inline-block;
		font-weight: bold;
		/* Uzun metinlerde taşmayı önle */
		max-width: 100%;
		word-break: break-word;
	}

	.label-manifesto,
	.label-cream {
		background-color: #1a1a1a !important;
		color: #f0e6d2 !important;
		display: inline-block;
		padding: 0.4rem 0.8rem;
		margin-top: 5px;
		/* Uzun metinlerde taşmayı önle */
		max-width: 100%;
		word-break: break-word;
	}

	/* ── SEÇİM KRİTERLERİ ── */
	.selection-criteria {
		margin-top: 1.5rem;
	}

	.criteria-list {
		list-style: none;
		padding: 0;
		margin-top: 0.8rem;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.thin-line {
		border: 0;
		border-top: 2px solid #000;
		margin: 2rem 0;
	}

	/* ── KOLEKTİF GRID ── */
	.collective-grid {
		display: grid;
		/* Kartlar yan yana, 240px altında tek sütun */
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.5rem;
	}

	.collective-card {
		border: 2px solid #000;
		padding: 1rem;
		background-color: #f0e6d2 !important;
		box-sizing: border-box;
	}

	.card-header {
		margin-bottom: 0.5rem;
	}

	.read-link {
		color: #1a1a1a !important;
		font-weight: bold;
		text-decoration: underline;
		display: inline-block;
		margin-top: 0.5rem;
	}

	/* ── SUBMISSIONS ── */
	.submissions {
		margin-top: 2rem;
		word-break: break-word;
	}

	.submissions p {
		line-height: 1.6;
	}

	.submit-btn {
		display: inline-block;
		margin-top: 1rem;
		padding: 0.5rem 1rem;
		background: #1a1a1a;
		color: #f0e6d2 !important;
		text-decoration: none;
		font-weight: bold;
		box-shadow: 4px 4px 0px #bc95d4;
		/* Küçük ekranlarda tam genişlik olsun */
	}

	/* ── MOBİL BREAKPOINT (≤480px) ── */
	@media (max-width: 480px) {
		main, article, .prose, .container {
			width: 95% !important;
			box-shadow: 5px 5px 0px #000; /* Gölgeyi küçült */
		}

		.collective-grid {
			grid-template-columns: 1fr; /* Tek sütun */
		}

		.submit-btn {
			display: block;         /* Tam genişlik buton */
			text-align: center;
			box-shadow: 3px 3px 0px #bc95d4;
		}

		.project-name {
			display: block; /* table yerine block, tam genişlik */
		}
	}
</style>