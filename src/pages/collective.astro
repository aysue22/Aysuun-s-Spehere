---
import BlogPost from '../layouts/BlogPost.astro';
---

<BlogPost
	title="Collective"
	description="A curated space for voices, works, and practices I resonate with."
>
	<div class="collective-page-container">
		<section class="collective-intro">
			<h1 class="project-name">Collective</h1> 
			<p class="manifesto-text">
				<span class="short-desc">Collective is not a guest post dump.</span> <br>
				<span class="label-manifesto">
					It is a curated space for voices, works and practices I resonate with.
				</span>
			</p>
		</section>

		<section class="selection-criteria">
			<h4 class="medium-tag">Selection Criteria</h4>
			<ul class="criteria-list">
				<li><span class="label-cream">Independent or non-institutional production</span></li>
				<li><span class="label-cream">Ethical alignment (feminism, ecology, social justice)</span></li>
				<li><span class="label-cream">Process over virality</span></li>
			</ul>
		</section>

		<hr class="thin-line" />

		<div class="collective-grid">
			<div class="collective-card">
				<div class="card-header">
					<span class="medium-tag">Publishing · Berlin</span>
				</div>
				<h3 class="project-name">Luna Press</h3>
				<p class="short-desc">Independent feminist publishing.</p>
				<a href="/collective/luna-press" class="read-link">→ Read</a>
			</div>
		</div>

		<section class="submissions">
			<p>This space is curated. You may suggest your work, but inclusion is not guaranteed.</p>
			<a href="/contact" class="submit-btn">Open Submissions</a>
		</section>
	</div>
</BlogPost>

<style is:global> 
	/* 1. DIŞ ARKA PLAN (Sitenin en arkası) */
	body {
		background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), 
                      url('https://aysuun-sphere.netlify.app/arkaplan7.jpg?v=1') !important;
    background-size: cover !important;
    background-position: center !important;
    background-attachment: fixed !important;
    background-repeat: no-repeat !important;
    background-color: #1a1a1a !important; 
    display: block !important;
	}

	/* 2. KREM BLOK (İçeriği taşıyan o 'kağıt' katmanı) */
	/* BlogPost içindeki ana yapıyı hedefliyoruz */
	main, .prose, article {
		background-color: #f0e6d2 !important; /* İstediğin o krem rengi */
		color: #1a1a1a !important;
		padding: 2rem !important;
		margin: 2rem auto !important;
		max-width: 850px !important;
		box-shadow: 10px 10px 0px #000; /* Zine estetiği için sert gölge */
		border: 2px solid #000;
	}

	/* 3. İÇERİK ÖZELLEŞTİRMELERİ */
	.project-name {
		display: table;
		background-color: #bc95d4 !important; /* Başlıkları mor yaparak krem üstünde patlatıyoruz */
		color: #1a1a1a !important;
		padding: 0.4rem 1rem;
		font-family: 'Georgia', serif;
		box-shadow: 4px 4px 0px #000;
		margin: 1rem 0;
	}

	.medium-tag {
		background-color: #1a1a1a !important;
		color: #f0e6d2 !important;
		padding: 0.2rem 0.6rem;
		font-size: 0.8rem;
		font-weight: bold;
		text-transform: uppercase;
		display: inline-block;
	}

	.short-desc {
		background-color: #bc95d4;
		color: #1a1a1a !important;
		padding: 0.3rem 0.6rem;
		display: inline-block;
		font-weight: bold;
	}

	.label-manifesto, .label-cream {
		background-color: #1a1a1a !important;
		color: #f0e6d2 !important;
		display: inline-block;
		padding: 0.4rem 0.8rem;
		margin-top: 5px;
	}

	.criteria-list {
		list-style: none;
		padding: 0;
	}

	.thin-line {
		border: 0;
		border-top: 2px solid #000;
		margin: 2rem 0;
	}

	.submit-btn {
		display: inline-block;
		margin-top: 1rem;
		padding: 0.5rem 1rem;
		background: #1a1a1a;
		color: #f0e6d2 !important;
		text-decoration: none;
		font-weight: bold;
		box-shadow: 4px 4px 0px #bc95d4;
	}

    .read-link {
        color: #1a1a1a !important;
        font-weight: bold;
        text-decoration: underline;
    }
</style>