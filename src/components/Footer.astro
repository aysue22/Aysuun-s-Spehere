---
const today = new Date();
---

<footer class="footer">
	<div class="footer-left">
		<img src="/covenjournallogo2.png" alt="Coven Journal" />
	</div>

	<div class="footer-center">
		<span>© {today.getFullYear()} The Coven Journal — All rights reserved.</span>
	</div>

	<div class="footer-right">
		<a href="#" aria-label="LinkedIn">
			<svg viewBox="0 0 24 24"><path d="M4 4h4v16H4zM6 2a2 2 0 100 4 2 2 0 000-4zm6 6h4v2h.1c.5-1 1.8-2 3.9-2 4 0 5 2.6 5 6v8h-4v-7c0-2-.5-3-2-3s-3 1-3 3v7h-4z"/></svg>
		</a>

		<a href="#" aria-label="Instagram">
			<svg viewBox="0 0 24 24"><path d="M7 2h10a5 5 0 015 5v10a5 5 0 01-5 5H7a5 5 0 01-5-5V7a5 5 0 015-5zm10 2H7a3 3 0 00-3 3v10a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3zm-5 3a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6zm4.5-2a1 1 0 110 2 1 1 0 010-2z"/></svg>
		</a>

		<a href="#" aria-label="GitHub">
			<svg viewBox="0 0 24 24"><path d="M12 .5a12 12 0 00-3.8 23.4c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.6-1.5-1.4-1.9-1.4-1.9-1.1-.8.1-.8.1-.8 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.9 1.3 3.6 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11 11 0 016 0C16.8 4.2 17.8 4.5 17.8 4.5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.2c0 .3.2.7.8.6A12 12 0 0012 .5z"/></svg>
		</a>

		<a href="#" aria-label="Twitter / X">
			<svg viewBox="0 0 24 24"><path d="M18.9 2H22l-6.8 7.8L23 22h-6.8l-5.3-6.7L4.8 22H2l7.3-8.4L1 2h6.9l4.8 6.1L18.9 2zm-1.2 18h1.9L6.1 4H4.1l13.6 16z"/></svg>
		</a>
	</div>
</footer>

<style>
.footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 10px 14px;
	height: 64px;
	background: transparent;
	color: #f5efda;
	font-weight: 600;
	font-size: 14px;
}

/* LEFT - BIGGER LOGO */
.footer-left img {
	height: 42px;
	object-fit: contain;
}

/* CENTER */
.footer-center {
	flex: 1;
	text-align: center;
}

/* RIGHT */
.footer-right {
	display: flex;
	gap: 10px; /* daha yakın ikonlar */
	align-items: center;
}

/* ICONS */
.footer-right a svg {
	width: 18px;
	height: 18px;
	fill: #f5efda;
	transition: 0.2s ease;
}

.footer-right a:hover svg {
	transform: translateY(-2px);
}

/* RESPONSIVE */
@media (max-width: 768px) {
	.footer {
		flex-direction: column;
		height: auto;
		gap: 10px;
		padding: 14px;
	}

	.footer-right {
		gap: 14px;
	}
}
</style>